# ============= SYSTEMCTL ALIASES ===============
alias resilio-enable="sudo systemctl enable resilio-sync.service"
alias resilio-disable="sudo systemctl disable resilio-sync.service"
alias resilio-stop="sudo systemctl stop resilio-sync.service"
alias resilio-start="sudo systemctl start resilio-sync.service"
alias resilio-status="sudo systemctl status resilio-sync.service"
alias resilio-restart="sudo systemctl restart resilio-sync.service"

alias nginx-stop="sudo systemctl stop nginx.service"
alias nginx-start="sudo systemctl start nginx.service"
alias nginx-status="sudo systemctl status nginx.service"
alias nginx-restart="sudo systemctl restart nginx.service"
alias nginx-disable="sudo systemctl disable nginx.service"
alias nginx-enable="sudo systemctl enable nginx.service"

alias uwsgi-stop="sudo systemctl stop uwsgi.service"
alias uwsgi-start="sudo systemctl start uwsgi.service"
alias uwsgi-status="sudo systemctl status uwsgi.service"
alias uwsgi-restart="sudo systemctl restart uwsgi.service"
alias uwsgi-disable="sudo systemctl disable uwsgi.service"
alias uwsgi-enable="sudo systemctl enable uwsgi.service"



